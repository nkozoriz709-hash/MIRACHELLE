style.css

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Inter', sans-serif;
    background-color: #FDFCF9;
    color: #1E1E1E;
    line-height: 1.5;
    scroll-behavior: smooth;
}

.container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 32px;
}

/* Navbar */
.navbar {
    position: fixed;
    top: 0;
    width: 100%;
    background: rgba(253, 252, 249, 0.92);
    backdrop-filter: blur(12px);
    z-index: 1000;
    padding: 18px 0;
    border-bottom: 1px solid rgba(0,0,0,0.05);
    transition: all 0.3s ease;
}

.nav-container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 32px;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.logo {
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: #2C2C2C;
}

.logo-icon {
    color: #B28B6F;
    margin-right: 6px;
}

.nav-links {
    display: flex;
    list-style: none;
    gap: 36px;
    align-items: center;
}

.nav-item {
    text-decoration: none;
    color: #2C2C2C;
    font-weight: 500;
    font-size: 0.95rem;
    transition: color 0.2s;
}

.nav-item:hover {
    color: #B28B6F;
}

.cart-icon-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    background: #F3F0EA;
    padding: 6px 14px;
    border-radius: 40px;
    transition: all 0.2s;
}

.cart-icon-btn:hover {
    background: #E8E2D8;
}

.mobile-menu-btn {
    display: none;
    font-size: 1.6rem;
    cursor: pointer;
}

/* Hero — с вашим фоном */
.hero {
    min-height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    position: relative;
    padding: 120px 24px 80px;
    background-image: url('https://images.pexels.com/photos/4041392/pexels-photo-4041392.jpeg?auto=compress&cs=tinysrgb&w=1600');
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    position: relative;
}

.hero::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.4);
    z-index: 1;
}

.hero-content {
    max-width: 700px;
    z-index: 2;
    position: relative;
    animation: fadeUp 0.9s cubic-bezier(0.2, 0.9, 0.4, 1.1);
    background: rgba(253, 252, 249, 0.45);
    backdrop-filter: blur(16px);
    border-radius: 32px;
    padding: 48px 56px;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.5);
}

.hero-tagline {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 4px;
    color: #B28B6F;
    font-weight: 600;
    margin-bottom: 20px;
    display: inline-block;
}

.hero-title {
    font-size: 3.6rem;
    font-weight: 500;
    line-height: 1.2;
    margin-bottom: 24px;
    color: #1E1E1E;
    letter-spacing: -0.02em;
}

.hero-desc {
    font-size: 1.1rem;
    color: #4A4A4A;
    max-width: 500px;
    margin: 0 auto 32px;
}

.btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #1E1E1E;
    color: white;
    padding: 12px 32px;
    border-radius: 40px;
    text-decoration: none;
    font-weight: 500;
    transition: all 0.3s;
    border: none;
    cursor: pointer;
}

.btn-primary:hover {
    background: #B28B6F;
    transform: scale(1.02);
    gap: 12px;
}

/* Products */
.products-section {
    padding: 100px 0;
    background: #FFFFFF;
}

.section-header {
    text-align: center;
    margin-bottom: 60px;
}

.section-subtitle {
    font-size: 0.75rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #B28B6F;
    font-weight: 500;
}

.section-header h2 {
    font-size: 2.5rem;
    font-weight: 500;
    margin: 12px 0 12px;
    color: #1E1E1E;
}

.products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 48px;
    margin-top: 20px;
}

.product-card {
    background: #FEFCF9;
    border-radius: 32px;
    padding: 32px 24px;
    text-align: center;
    transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    box-shadow: 0 5px 20px rgba(0,0,0,0.02);
    border: 1px solid #F0EBE3;
    cursor: pointer;
    position: relative;
    overflow: hidden;
}

.product-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(178,139,111,0.05), transparent);
    transition: left 0.6s ease;
}

.product-card:hover::before {
    left: 100%;
}

.product-card:hover {
    transform: translateY(-12px);
    box-shadow: 0 25px 45px -12px rgba(0,0,0,0.12);
    border-color: #DACFC2;
}

.product-image {
    width: 100%;
    height: 260px;
    object-fit: cover;
    border-radius: 24px;
    margin-bottom: 24px;
    transition: transform 0.5s ease;
}

.product-card:hover .product-image {
    transform: scale(1.03);
}

.product-card h3 {
    font-size: 1.7rem;
    font-weight: 500;
    margin-bottom: 8px;
    color: #1E1E1E;
}

.product-volume {
    font-size: 0.85rem;
    color: #B28B6F;
    font-weight: 500;
    margin-bottom: 12px;
    letter-spacing: 0.5px;
}

.product-card p {
    color: #6B5A4E;
    font-size: 0.9rem;
    margin-bottom: 16px;
    line-height: 1.5;
}

.product-price {
    font-size: 1.5rem;
    font-weight: 600;
    color: #B28B6F;
    margin: 16px 0;
    display: flex;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
}

.product-price-rub {
    display: inline-block;
}

.product-price-byn {
    font-size: 0.9rem;
    color: #8B7A6B;
    font-weight: 400;
    display: inline-block;
}

.add-to-cart {
    background: none;
    border: 1.5px solid #D4C9BC;
    padding: 10px 20px;
    border-radius: 40px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s ease;
    margin-top: 8px;
    width: 100%;
}

.add-to-cart:hover {
    background: #1E1E1E;
    color: white;
    border-color: #1E1E1E;
    transform: translateY(-2px);
}

/* Product Modal */
.product-modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.6);
    backdrop-filter: blur(8px);
    z-index: 1100;
    justify-content: center;
    align-items: center;
    animation: fadeIn 0.3s ease;
}

.product-modal-content {
    background: white;
    max-width: 900px;
    width: 90%;
    border-radius: 40px;
    overflow: hidden;
    animation: slideUp 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 24px 32px;
    border-bottom: 1px solid #F0EBE3;
    background: #FEFCF9;
}

.modal-header h3 {
    font-size: 1.8rem;
    font-weight: 500;
    color: #1E1E1E;
}

.close-modal {
    font-size: 32px;
    cursor: pointer;
    color: #8B7A6B;
    transition: all 0.2s;
    line-height: 1;
}

.close-modal:hover {
    color: #B28B6F;
    transform: rotate(90deg);
}

.modal-body {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 32px;
    padding: 32px;
    background: white;
}

.modal-image {
    border-radius: 24px;
    overflow: hidden;
    background: #F9F6F0;
}

.modal-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
}

.modal-image:hover img {
    transform: scale(1.05);
}

.modal-info {
    display: flex;
    flex-direction: column;
    gap: 20px;
}

.modal-volume {
    font-size: 0.9rem;
    color: #B28B6F;
    font-weight: 500;
    margin-top: -10px;
    margin-bottom: 5px;
}

.modal-description {
    font-size: 1rem;
    line-height: 1.6;
    color: #4A4A4A;
    margin-bottom: 8px;
}

.modal-ingredients h4, .modal-benefits h4 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 12px;
    color: #B28B6F;
    display: flex;
    align-items: center;
    gap: 8px;
}

.modal-ingredients p {
    font-size: 0.9rem;
    line-height: 1.6;
    color: #5A5A5A;
}

.modal-benefits ul {
    list-style: none;
    padding-left: 0;
}

.modal-benefits li {
    padding: 6px 0;
    padding-left: 24px;
    position: relative;
    font-size: 0.9rem;
    color: #4A4A4A;
}

.modal-benefits li::before {
    content: '✦';
    position: absolute;
    left: 0;
    color: #B28B6F;
}

.modal-price {
    margin-top: 16px;
    padding-top: 20px;
    border-top: 2px solid #F0EBE3;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
}

.modal-price-rub {
    font-size: 1.8rem;
    font-weight: 600;
    color: #B28B6F;
}

.modal-price-byn {
    font-size: 1.1rem;
    color: #8B7A6B;
    font-weight: 400;
}

/* About */
.about-section {
    padding: 100px 0;
    background: #FEFCF9;
}

.about-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
}

.about-img .img-placeholder {
    background: linear-gradient(135deg, #EFE8E0 0%, #E8DFD4 100%);
